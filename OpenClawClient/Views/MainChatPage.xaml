<Page
    x:Class="OpenClawClient.Views.MainChatPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="OnLoaded">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ===== SIDEBAR ===== -->
        <Border Grid.Column="0" BorderThickness="0,0,1,0"
                BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Заголовок сессий -->
                <Border Grid.Row="0" Padding="12,12" BorderThickness="0,0,0,1"
                        BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Чаты" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Content="✚" Click="OnNewSessionClick" Width="32" Height="32" Padding="0" FontSize="16" />
                    </Grid>
                </Border>

                <!-- Список сессий -->
                <ListView
                    Grid.Row="1"
                    x:Name="SessionListView"
                    ItemsSource="{x:Bind ViewModel.Sessions}"
                    SelectedItem="{x:Bind ViewModel.SelectedSession, Mode=TwoWay}"
                    SelectionMode="Single"
                    ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8,6" CornerRadius="8">
                                <StackPanel>
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="14" />
                                    <TextBlock Text="{Binding Preview}" FontSize="12"
                                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                               TextTrimming="CharacterEllipsis" MaxLines="1" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- Футер: статус соединения -->
                <Border Grid.Row="2" Padding="12,8" BorderThickness="0,1,0,0"
                        BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Ellipse x:Name="StatusIndicator" Width="8" Height="8" VerticalAlignment="Center" Fill="#F04747" />
                        <TextBlock x:Name="StatusLabel" Text="{x:Bind ViewModel.StatusText}" FontSize="11"
                                   Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ===== CHAT AREA ===== -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Шапка -->
            <Border Grid.Row="0" Padding="12,8" BorderThickness="0,0,0,1"
                    BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{x:Bind ViewModel.ChatTitle}" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Button Grid.Column="1" Content="⚙" Click="OnSettingsClick" Margin="0,0,8,0" FontSize="16" />
                    <Button Grid.Column="2" Content="✕" Click="OnExitClick" Background="Transparent" FontSize="16" />
                </Grid>
            </Border>

            <!-- Сообщения -->
            <ScrollViewer x:Name="MessageScroller" Grid.Row="1"
                          VerticalScrollBarVisibility="Auto" VerticalScrollMode="Auto" Padding="16,8">
                <ItemsControl x:Name="MessageList" ItemsSource="{x:Bind ViewModel.Messages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,0,0,8">
                                <Border
                                    HorizontalAlignment="{Binding Alignment}"
                                    CornerRadius="12" Padding="12,8" MaxWidth="520"
                                    Background="{ThemeResource SystemAccentColor}"
                                    Margin="{Binding BubbleMargin}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Text}" TextWrapping="Wrap" FontSize="14" Foreground="White" />
                                        <TextBlock Text="{Binding StatusIcon}" FontSize="11" Foreground="#aaa"
                                                   HorizontalAlignment="Right" Margin="0,4,0,0" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Панель ввода -->
            <Border Grid.Row="2" Padding="12,8" BorderThickness="0,1,0,0"
                    BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="📎" Click="OnAttachFileClick" Width="36" Height="36" Padding="0" FontSize="16" Margin="0,0,8,0" />
                    <TextBox x:Name="InputBox" Grid.Column="1"
                             PlaceholderText="Напишите сообщение..."
                             Text="{x:Bind ViewModel.InputText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="False" KeyDown="OnInputKeyDown" Margin="0,0,8,0" />
                    <Button Grid.Column="2" Content="Отправить" Click="OnSendClick" Style="{StaticResource AccentButtonStyle}" />
                </Grid>
            </Border>

            <!-- Оверлей загрузки -->
            <Border Grid.Row="1" Background="#80000000"
                    Visibility="{x:Bind ViewModel.IsWaiting, Converter={StaticResource BoolToVis}}"
                    VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
                    <ProgressRing IsActive="{x:Bind ViewModel.IsWaiting}" Width="40" Height="40" Foreground="White" />
                    <TextBlock Text="{x:Bind ViewModel.StatusText}" Foreground="White" FontSize="14" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
