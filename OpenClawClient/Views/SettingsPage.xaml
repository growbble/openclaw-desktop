<Page
    x:Class="OpenClawClient.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer>
        <StackPanel Spacing="16" Padding="32" MaxWidth="500">
            <TextBlock Text="Настройки" FontSize="20" FontWeight="SemiBold" />
            <TextBlock Text="Подключение к серверу OpenClaw" FontSize="14"
                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />

            <!-- API Endpoint -->
            <TextBox x:Name="ServerUrlBox" Header="API Endpoint" PlaceholderText="http://ваш-vds:18789" />

            <!-- Gateway Token -->
            <PasswordBox x:Name="AuthTokenBox" Header="Gateway Token" PlaceholderText="Bearer token" />

            <!-- Agent ID -->
            <TextBox x:Name="AgentIdBox" Header="ID агента" PlaceholderText="openclaw" />

            <TextBlock Text="Файлы" FontSize="14" FontWeight="SemiBold" Margin="0,8,0,0" />

            <!-- Download folder -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBox x:Name="DownloadPathBox" Header="Папка для загрузок" Width="380" IsReadOnly="True" />
                <Button Content="Обзор..." Click="OnBrowseFolder" />
            </StackPanel>

            <!-- Auto-download options -->
            <CheckBox x:Name="AutoImagesCheck" Content="Автоматически скачивать изображения" />
            <CheckBox x:Name="AutoDocsCheck" Content="Автоматически скачивать документы" />

            <TextBox x:Name="MaxSizeBox" Header="Макс. размер для автозагрузки (MB)" PlaceholderText="20"
                     InputScope="Number" />

            <TextBlock Text="Уведомления" FontSize="14" FontWeight="SemiBold" Margin="0,8,0,0" />
            <ToggleSwitch x:Name="NotificationsSwitch" Header="Системные уведомления" OnContent="Вкл" OffContent="Выкл" />

            <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,16,0,0">
                <Button Content="Проверить соединение" Click="OnCheckConnection" Style="{StaticResource AccentButtonStyle}" />
                <Button Content="Сохранить" Click="OnSave" />
                <Button Content="Отмена" Click="OnCancel" />
            </StackPanel>

            <TextBlock x:Name="StatusText" FontSize="14" Margin="0,8,0,0" />
        </StackPanel>
    </ScrollViewer>
</Page>
